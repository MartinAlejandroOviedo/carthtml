[Unit]
Description=SLStore carthtml
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/carthtml
Environment=NODE_ENV=production
Environment=PORT=3000
EnvironmentFile=-/var/www/carthtml/deploy/env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
